{
	"name": "openai-cache",
	"version": "1.0.35",
	"type": "module",
	"main": "dist/openai_cache.js",
	"types": "dist/openai_cache.d.ts",
	"exports": {
		".": {
			"types": "./dist/openai_cache.d.ts",
			"default": "./dist/openai_cache.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"sample:image_generation": "tsx examples/image_generation_example.ts",
		"sample:image_understanding": "tsx examples/image_understanding_example.ts",
		"sample:openai_cache": "tsx examples/openai_cache_example.ts",
		"sample:tts": "tsx examples/tts_example.ts",
		"open_cache:clean": "rm -f ./examples/.openai_cache.sqlite",
		"build": "tsc -p tsconfig.json",
		"build:watch": "tsc -p tsconfig.json --watch",
		"clean": "rm -rf dist",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run test && npm run build",
		"test": "tsx --test ./test/*_test.ts",
		"test:watch": "tsx --test --watch ./test/*_test.ts",
		"publish:all": "npm run build && npm version patch && npm publish --access public"
	},
	"keywords": [
		"openai",
		"cache",
		"caching",
		"keyv",
		"sqlite",
		"typescript"
	],
	"author": "jerome etienne <jerome.etienne@example.com>",
	"license": "MIT",
	"description": "A caching layer for OpenAI API calls, designed to improve performance and reduce costs.",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jeromeetienne/openai-cache.git",
		"directory": "packages/openai_cache"
	},
	"homepage": "https://github.com/jeromeetienne/openai-cache/tree/main/#cache-openai",
	"bugs": {
		"url": "https://github.com/jeromeetienne/openai-cache/issues"
	},
	"devDependencies": {
		"@keyv/sqlite": "^4.0.8",
		"@openai/agents": "^0.8.1",
		"@types/node": "^25.5.2",
		"keyv": "^5.6.0",
		"openai": "^6.17.0",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"cacheable": "^2.3.4",
		"chalk": "^5.6.2",
		"openai-cache": "^1.0.29"
	}
}